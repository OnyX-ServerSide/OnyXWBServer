async function updateGames() {
    try {
        const res = await fetch(`${RENDER_URL}/get_games`);
        const games = await res.json();
        const container = document.getElementById('game-list');
        
        if (Object.keys(games).length > 0) {
            container.innerHTML = ""; 
            for (let name in games) {
                const g = games[name];
                container.innerHTML += `
                    <div class="game-card">
                        <div class="game-header">
                            <div class="game-icon-box">🎮</div>
                            <div class="game-title">${name}</div>
                        </div>
                        
                        <div class="game-details">
                            <div class="detail-item">
                                <b>AUTHOR</b>
                                <span>${g.author || 'Unknown'}</span>
                            </div>
                            <div class="detail-item">
                                <b>PLAYERS</b>
                                <span>${g.playerCount}/${g.maxPlayers}</span>
                            </div>
                            <div class="detail-item">
                                <b>PLACE ID</b>
                                <span>${g.placeId}</span>
                            </div>
                            <div class="detail-item">
                                <b>STATUS</b>
                                <span style="color: #4CAF50;">● Online</span>
                            </div>
                        </div>

                        <button class="btn btn-exec" style="width: 100%; margin-top: 5px;" onclick="alert('Connected to ${name}')">
                            Connect Server
                        </button>
                    </div>
                `;
            }
        }
    } catch (e) { console.log("Searching for games..."); }
}
